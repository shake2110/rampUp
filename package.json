{
  "name": "rampup-monorepo",
  "version": "1.0.0",
  "description": "AI Tutor Screener - Monorepo",
  "scripts": {
    "dev": "npm run dev:frontend",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && uvicorn main:app --host 0.0.0.0 --port 8001 --reload",
    "install:all": "npm install --prefix frontend && pip install -r backend/requirements.txt",
    "build": "cd frontend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "check:frontend": "cd frontend && npm run check:ci",
    "check:ci": "cd frontend && npm run check:ci"
  },
  "keywords": [],
