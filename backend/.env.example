# AI Tutor Screener - Backend Environment Variables
# Copy this to .env and fill in the values

# API Key for OpenRouter (LLM)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Supabase Credentials
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_or_service_key_here

# Optional: Whisper model size (tiny, base, small, medium, large)
WHISPER_MODEL=base

# Port (Railway usually sets the PORT environment variable automatically)
PORT=8001
